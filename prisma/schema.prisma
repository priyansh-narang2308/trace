generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String       @id @default(cuid())
  projectId   String       @unique  // On-chain project ID
  name        String
  description String
  isPublic    Boolean      @default(true)
  ownerAddress String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  checkpoints Checkpoint[]
  collaborators Collaborator[]

  @@index([ownerAddress])
  @@index([projectId])
}

model Checkpoint {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [projectId])
  checkpointHash  String   @unique  // On-chain hash
  txHash          String   // Monad transaction hash
  screenshotUrl   String?
  description     String
  creatorAddress  String
  collaborators   String[] // JSON array of addresses
  checkpointType  String   // MANUAL, GIT_COMMIT, DEPLOYMENT, SCREENSHOT, COLLABORATION
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([projectId])
  @@index([checkpointHash])
  @@index([creatorAddress])
}

model Collaborator {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [projectId])
  address     String
  addedAt     DateTime @default(now())

  @@unique([projectId, address])
  @@index([address])
}

model User {
  id          String   @id @default(cuid())
  address     String   @unique
  passkeyId   String?  // WebAuthn credential ID
  createdAt   DateTime @default(now())
}
